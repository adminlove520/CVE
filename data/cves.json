              "version": "< 2.2.23",
              "status": "affected"
            },
            {
              "version": ">= 3.0.0.beta1, < 3.1.21",
              "status": "affected"
            },
            {
              "version": ">= 3.2.0, < 3.2.6",
              "status": "affected"
            }
          ]
        }
      ],
