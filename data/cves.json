        },
        {
          "url": "https://plugins.trac.wordpress.org/changeset/3476067/woo-product-feed-pro",
          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "jkohlbach",
          "product": "Product Feed PRO for WooCommerce by AdTribes – Product Feeds for WooCommerce",
          "versions": [
            {
              "version": "13.4.6",
              "status": "affected",
              "lessThanOrEqual": "13.5.2.1",
              "versionType": "semver"
            }
          ],
          "defaultStatus": "unaffected"
        }
      ],
      "problemType": [
        "CWE-352 Cross-Site Request Forgery (CSRF)"
      ],
      "fix_suggestion": "无法生成修复建议"
    },
