      "id": "CVE-2026-3334",
      "publishedDate": "2026-03-21T03:26:29.056Z",
      "lastModifiedDate": "2026-03-23T17:25:30.911Z",
      "description": "The CMS Commander plugin for WordPress is vulnerable to SQL Injection via the 'or_blogname', 'or_blogdescription', and 'or_admin_email' parameters in all versions up to, and including, 2.288. This is due to insufficient escaping on the user supplied parameters and lack of sufficient preparation on the existing SQL queries in the restore workflow. This makes it possible for authenticated attackers, with CMS Commander API key access, to append additional SQL queries into already existing queries that can be used to extract sensitive information from the database.",
      "severity": 8.8,
      "references": [
        {
          "url": "https://www.wordfence.com/threat-intel/vulnerabilities/id/0311b546-01a4-4be8-97f3-6df6cd79c3fe?source=cve",
          "type": "reference"
        },
        {
          "url": "https://plugins.trac.wordpress.org/browser/cms-commander-client/tags/2.288/lib/CMSC/Backup.php#L1639",
          "type": "reference"
        },
        {
          "url": "https://plugins.trac.wordpress.org/browser/cms-commander-client/tags/2.288/lib/CMSC/Backup.php#L1366",
          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "thoefter",
          "product": "CMS Commander – Manage Multiple Sites",
          "versions": [
            {
              "version": "*",
              "status": "affected",
              "lessThanOrEqual": "2.288",
              "versionType": "semver"
            }
          ],
          "defaultStatus": "unaffected"
        }
      ],
      "problemType": [
        "CWE-89 Improper Neutralization of Special Elements used in an SQL Command ('SQL Injection')"
