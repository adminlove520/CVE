        },
        {
          "url": "https://plugins.trac.wordpress.org/changeset?old_path=/everest-forms/tags/3.4.3&new_path=/everest-forms/tags/3.4.4",
          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "wpeverest",
