          "type": "reference"
        },
        {
          "url": "https://datatracker.ietf.org/doc/html/rfc8628#section-5.4",
          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "openbao",
          "product": "openbao",
          "versions": [
            {
              "version": "< 2.5.2",
              "status": "affected"
            }
          ]
        }
      ],
      "problemType": [
        "CWE-384: Session Fixation"
      ],
      "fix_suggestion": "无法生成修复建议"
