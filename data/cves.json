        {
          "url": "https://github.com/kestra-io/kestra/releases/tag/v1.3.7",
          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "kestra-io",
          "product": "kestra",
          "versions": [
            {
              "version": "< 1.3.7",
              "status": "affected"
            }
          ]
        }
      ],
      "problemType": [
        "CWE-89: Improper Neutralization of Special Elements used in an SQL Command ('SQL Injection')"
      ],
