          "vendor": "smallstep",
          "product": "certificates",
          "versions": [
            {
              "version": "< 0.30.0",
              "status": "affected"
            }
          ]
        }
      ],
      "problemType": [
        "CWE-287: Improper Authentication",
        "CWE-295: Improper Certificate Validation"
      ],
      "fix_suggestion": "无法生成修复建议"
