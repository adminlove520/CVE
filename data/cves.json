          "type": "reference"
        }
      ],
      "affected": [
        {
          "vendor": "SuiteCRM",
          "product": "SuiteCRM",
          "versions": [
            {
              "version": "< 7.15.1",
              "status": "affected"
            },
            {
              "version": ">= 8.0.0, < 8.9.3",
              "status": "affected"
            }
          ]
        }
      ],
      "problemType": [
        "CWE-90: Improper Neutralization of Special Elements used in an LDAP Query ('LDAP Injection')"
      ],
      "fix_suggestion": "无法生成修复建议"
    },
