              "version": "< 0.22.0",
              "status": "affected"
            }
          ]
        }
      ],
      "problemType": [
        "CWE-1289: Improper Validation of Unsafe Equivalence in Input"
      ],
      "fix_suggestion": "无法生成修复建议"
    },
